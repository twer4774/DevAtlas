# Database
DATABASE_URL=postgresql+asyncpg://gittrack:gittrack@localhost:5434/gittrack

# MinIO / S3
S3_ENDPOINT_URL=http://localhost:9002
S3_BUCKET=gittrack-attachments
S3_ACCESS_KEY=gittrack
S3_SECRET_KEY=gittrackSecret

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Token encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=http://localhost:5173
