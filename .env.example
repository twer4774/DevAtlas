# Shared across all services — must be identical
JWT_SECRET_KEY=change-me-run-openssl-rand-hex-32

# GitHub OAuth App (create at github.com/settings/developers)
# Callback URL: http://localhost:8001/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# SMTP (이메일 초대 발송 — 비워두면 이메일 없이 링크만 발급)
# Gmail 사용 시: https://myaccount.google.com/apppasswords 에서 앱 비밀번호 발급
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
